      <aliases enabled='yes' />
      <column caption='2-Alpha Code' datatype='string' name='[2-alpha code]' role='dimension' type='nominal' />
      <column caption='Primary Economic Sector' datatype='string' name='[Calculation_1572319225303318529]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Country Name] IN (&quot;Maldives&quot;, &quot;Thailand&quot;, &quot;Bahamas&quot;, &quot;Greece&quot;, &quot;Iceland&quot;) THEN &quot;Tourism&quot;&#10;ELSEIF [Country Name] IN (&quot;Germany&quot;, &quot;Japan&quot;, &quot;China&quot;, &quot;South Korea&quot;) THEN &quot;Manufacturing&quot;&#10;ELSEIF [Country Name] IN (&quot;Nigeria&quot;, &quot;Saudi Arabia&quot;, &quot;Russia&quot;, &quot;Venezuela&quot;) THEN &quot;Oil &amp; Gas&quot;&#10;ELSEIF [Country Name] IN (&quot;India&quot;, &quot;Brazil&quot;, &quot;Indonesia&quot;, &quot;Vietnam&quot;) THEN &quot;Agriculture &amp; Mixed&quot;&#10;ELSEIF [Country Name] IN (&quot;United States&quot;, &quot;United Kingdom&quot;, &quot;Switzerland&quot;, &quot;Singapore&quot;) THEN &quot;Finance &amp; Services&quot;&#10;ELSE &quot;Other&quot;&#10;END' />
      </column>
      <column caption='Rank' datatype='integer' name='[Calculation_274297366973358081]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK(SUM([Pivot Field Values]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Rank_AVG' datatype='integer' name='[Calculation_274297366978064386]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK(AVG([Pivot Field Values]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Rank_GDP' datatype='integer' name='[Calculation_274297367018401795]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK_UNIQUE(-AVG([Pivot Field Values]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Angle_Polar' datatype='real' name='[Calculation_274297367019991044]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Income Group] = &quot;Low income&quot; THEN 0&#10;ELSEIF [Income Group] = &quot;Lower middle income&quot; THEN PI() / 2&#10;ELSEIF [Income Group] = &quot;Upper middle income&quot; THEN PI()&#10;ELSE PI() * 3 / 2&#10;END' />
      </column>
      <column caption='X' datatype='real' name='[Calculation_274297367020548101]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Pivot Field Values] * SIN([Calculation_274297367019991044])' />
      </column>
      <column caption='Y' datatype='real' name='[Calculation_274297367020814342]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Pivot Field Values] * COS([Calculation_274297367019991044])' />
      </column>
      <column caption='Income Order' datatype='integer' name='[Calculation_274297367022522375]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CASE [Income Group]&#10;WHEN &quot;Low income&quot; THEN 1&#10;WHEN &quot;Lower middle income&quot; THEN 2&#10;WHEN &quot;Upper middle income&quot; THEN 3&#10;WHEN &quot;High income&quot; THEN 4&#10;END' />
      </column>
      <column caption='Year_1' datatype='date' name='[Calculation_274297368025456649]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATE(MAKEDATE(INT([Pivot Field Names]), 1, 1))' />
      </column>
