    <worksheet name='5'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontcolor='#4e79a7' fontname='Tableau Bold'>COVID-19 Impact on Global GDP (2019–2022) </run>
          </formatted-text>
        </title>
        <caption>
          <formatted-text>
            <run bold='true' fontcolor='#0e0e0e' fontname='Tableau Medium' lmargin='225'>This slope chart illustrates how different global regions were affected by the COVID-19 pandemic, with sharp GDP declines in 2020 followed by varied recovery paths. Sub-Saharan Africa and South Asia experienced steep contractions, while Latin America &amp; Caribbean showed the strongest rebound in 2021. East Asia &amp; Pacific, despite early stability, had a slower recovery. The chart highlights how economic resilience and rebound trajectories varied significantly by region in the post-pandemic landscape.</run>
            <run fontcolor='#000000' fontname='Tableau Medium' lmargin='225'>Æ </run>
          </formatted-text>
        </caption>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Country - Metadata+ (DV_Proejct)' name='federated.0ezjeed1f3uhko19q19sy04pyqxb' />
          </datasources>
          <datasource-dependencies datasource='federated.0ezjeed1f3uhko19q19sy04pyqxb'>
            <column caption='Year' datatype='string' name='[Pivot Field Names]' role='dimension' type='nominal' />
            <column caption='GDP Growth %' datatype='real' name='[Pivot Field Values]' role='measure' type='quantitative' />
            <column datatype='string' name='[Region]' role='dimension' semantic-role='[Country].[Name]' type='nominal' />
            <column caption='Year1' datatype='date' name='[Year]' role='dimension' type='quantitative' />
            <column-instance column='[Pivot Field Values]' derivation='Avg' name='[avg:Pivot Field Values:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Pivot Field Names]' derivation='None' name='[none:Pivot Field Names:nk]' pivot='key' type='nominal' />
            <column-instance column='[Region]' derivation='None' name='[none:Region:nk]' pivot='key' type='nominal' />
            <column-instance column='[Year]' derivation='Year' name='[yr:Year:ok]' pivot='key' type='ordinal' />
          </datasource-dependencies>
          <filter class='categorical' column='[federated.0ezjeed1f3uhko19q19sy04pyqxb].[Exclusions (Region,Year)]'>
            <groupfilter function='except' user:ui-domain='database' user:ui-enumeration='exclusive' user:ui-marker='enumerate'>
              <groupfilter function='crossjoin'>
                <groupfilter function='level-members' level='[none:Region:nk]' />
                <groupfilter function='level-members' level='[none:Pivot Field Names:nk]' />
              </groupfilter>
              <groupfilter function='crossjoin'>
                <groupfilter function='member' level='[none:Region:nk]' member='%null%' />
                <groupfilter function='union'>
                  <groupfilter function='member' level='[none:Pivot Field Names:nk]' member='&quot;2020 (Yr2020)&quot;' />
                  <groupfilter function='member' level='[none:Pivot Field Names:nk]' member='&quot;2021 (Yr2021)&quot;' />
                  <groupfilter function='member' level='[none:Pivot Field Names:nk]' member='&quot;2023 (Yr2023)&quot;' />
                </groupfilter>
              </groupfilter>
            </groupfilter>
          </filter>
          <filter class='categorical' column='[federated.0ezjeed1f3uhko19q19sy04pyqxb].[none:Region:nk]'>
            <groupfilter function='except' user:ui-domain='relevant' user:ui-enumeration='exclusive' user:ui-marker='enumerate'>
              <groupfilter function='level-members' level='[none:Region:nk]' />
              <groupfilter function='member' level='[none:Region:nk]' member='%null%' />
            </groupfilter>
          </filter>
          <filter class='categorical' column='[federated.0ezjeed1f3uhko19q19sy04pyqxb].[yr:Year:ok]' filter-group='4'>
            <groupfilter function='union' user:ui-domain='database' user:ui-enumeration='inclusive' user:ui-marker='enumerate'>
              <groupfilter function='member' level='[yr:Year:ok]' member='2019' />
