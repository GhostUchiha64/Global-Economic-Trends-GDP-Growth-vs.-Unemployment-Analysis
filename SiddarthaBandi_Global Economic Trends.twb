    <worksheet name='2'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontcolor='#4e79a7'>Bottom 15 GDP Growth Countries</run>
          </formatted-text>
        </title>
        <caption>
          <formatted-text>
            <run bold='true' fontcolor='#0e0e0e' fontname='Tableau Medium' lmargin='225'>This bar chart showcases the top 10 countries with the highest GDP growth in 2022. Guyana leads the list with an extraordinary 180.4% growth, driven largely by its booming oil sector. Other notable countries include Ireland, Ethiopia, and Tajikistan, reflecting strong economic rebounds and sectoral growth across diverse regions</run>
            <run bold='true' fontcolor='#000000' fontname='Tableau Medium' lmargin='225'>Æ </run>
          </formatted-text>
        </caption>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Country - Metadata+ (DV_Proejct)' name='federated.0ezjeed1f3uhko19q19sy04pyqxb' />
          </datasources>
          <datasource-dependencies datasource='federated.0ezjeed1f3uhko19q19sy04pyqxb'>
            <column caption='Rank' datatype='integer' name='[Calculation_274297366973358081]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='RANK(SUM([Pivot Field Values]))'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column datatype='string' name='[Country Name]' role='dimension' semantic-role='[Country].[ISO3166_2]' type='nominal' />
            <column caption='Year' datatype='string' name='[Pivot Field Names]' role='dimension' type='nominal' />
            <column caption='GDP Growth %' datatype='real' name='[Pivot Field Values]' role='measure' type='quantitative' />
            <column datatype='string' name='[Series Name]' role='dimension' type='nominal' />
            <column-instance column='[Pivot Field Values]' derivation='Avg' name='[avg:Pivot Field Values:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Country Name]' derivation='None' name='[none:Country Name:nk]' pivot='key' type='nominal' />
            <column-instance column='[Pivot Field Names]' derivation='None' name='[none:Pivot Field Names:nk]' pivot='key' type='nominal' />
            <column-instance column='[Series Name]' derivation='None' name='[none:Series Name:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_274297366973358081]' derivation='User' name='[usr:Calculation_274297366973358081:qk]' pivot='key' type='quantitative'>
              <table-calc ordering-type='Columns' />
            </column-instance>
          </datasource-dependencies>
          <filter class='categorical' column='[federated.0ezjeed1f3uhko19q19sy04pyqxb].[none:Country Name:nk]'>
            <groupfilter count='15' end='bottom' function='end' units='records' user:ui-marker='end' user:ui-top-by-field='true'>
              <groupfilter direction='DESC' expression='AVG([Pivot Field Values])' function='order' user:ui-marker='order'>
