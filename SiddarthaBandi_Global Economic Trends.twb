    <worksheet name='13'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontcolor='#4e79a7' fontname='Tableau Bold'>Sectoral Vulnerability: GDP Drop by Primary Economic Activity </run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Country - Metadata+ (DV_Proejct)' name='federated.0ezjeed1f3uhko19q19sy04pyqxb' />
          </datasources>
          <datasource-dependencies datasource='federated.0ezjeed1f3uhko19q19sy04pyqxb'>
            <column caption='Primary Economic Sector' datatype='string' name='[Calculation_1572319225303318529]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Country Name] IN (&quot;Maldives&quot;, &quot;Thailand&quot;, &quot;Bahamas&quot;, &quot;Greece&quot;, &quot;Iceland&quot;) THEN &quot;Tourism&quot;&#10;ELSEIF [Country Name] IN (&quot;Germany&quot;, &quot;Japan&quot;, &quot;China&quot;, &quot;South Korea&quot;) THEN &quot;Manufacturing&quot;&#10;ELSEIF [Country Name] IN (&quot;Nigeria&quot;, &quot;Saudi Arabia&quot;, &quot;Russia&quot;, &quot;Venezuela&quot;) THEN &quot;Oil &amp; Gas&quot;&#10;ELSEIF [Country Name] IN (&quot;India&quot;, &quot;Brazil&quot;, &quot;Indonesia&quot;, &quot;Vietnam&quot;) THEN &quot;Agriculture &amp; Mixed&quot;&#10;ELSEIF [Country Name] IN (&quot;United States&quot;, &quot;United Kingdom&quot;, &quot;Switzerland&quot;, &quot;Singapore&quot;) THEN &quot;Finance &amp; Services&quot;&#10;ELSE &quot;Other&quot;&#10;END' />
            </column>
            <column datatype='string' name='[Country Name]' role='dimension' semantic-role='[Country].[ISO3166_2]' type='nominal' />
